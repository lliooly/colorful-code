{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Colorful Code",
  "version": "0.0.0",
  "identifier": "com.colorfulcode.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @colorful-code/web dev",
    "devUrl": "http://localhost:3000/agent",
    "beforeBuildCommand": "pnpm --filter @colorful-code/web build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Colorful Code",
        "label": "main",
        "url": "/agent",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "transparent": true,
        "backgroundColor": "#00000000",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 24,
          "y": 26
        },
        "devtools": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
