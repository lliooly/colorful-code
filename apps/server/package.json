{
  "name": "@colorful-code/server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "bun scripts/build-production.ts",
    "lint": "eslint src scripts test --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test-foundation.json --noEmit",
    "test": "pnpm --filter @colorful-code/tool-runtime --filter @colorful-code/prompts build && bun test ./test",
    "fixture:legacy": "bun scripts/create-legacy-fixture.ts",
    "fixture:legacy-manifest": "bun scripts/generate-legacy-schema-manifest.ts",
    "db:backup": "bun scripts/backup-database.ts",
    "start": "bun src/main.ts",
    "start:prod": "bun src/main.ts",
    "clean": "rm -rf dist dist-test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@colorful-code/prompts": "workspace:*",
    "@colorful-code/schema": "workspace:*",
    "@colorful-code/shared": "workspace:*",
    "@colorful-code/tool-runtime": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "drizzle-orm": "^0.45.2",
    "openai": "^6.45.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1"
  }
}
