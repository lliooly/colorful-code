{
  "name": "@colorful-code/server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @colorful-code/tool-runtime build && tsc -p tsconfig.test.json && node --test dist-test/test/*.js",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "clean": "rm -rf dist dist-test"
  },
  "dependencies": {
    "@colorful-code/prompts": "workspace:*",
    "@colorful-code/schema": "workspace:*",
    "@colorful-code/shared": "workspace:*",
    "@colorful-code/tool-runtime": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/node": "^26.0.1"
  }
}
